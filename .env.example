# Copie para `.env.local` e preencha (Vite expõe apenas variáveis com prefixo VITE_).
# Este app é Vite + React — não use NEXT_PUBLIC_* aqui.

VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Opcional: chave publishable do dashboard (createClient)
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Obrigatório para chamadas fetch às Edge Functions: JWT anon "anon" "public" (eyJ...)
# Sem isso, use só publishable acima: o app usa o anon embutido em src/utils/supabase/info.tsx para as functions.
VITE_SUPABASE_ANON_KEY=
